#!/usr/bin/env bash

playerctl --player=playerctld,%any --follow metadata --format '{{ status }} {{ artist }} - {{ title }} [{{ duration(position) }}/{{ duration(mpris:length) }}]' |
    sed --unbuffered '
        # replace status with emoji
        s/^Playing/’üŗ/ # ¾░ÉŖ
        s/^Paused/’üī/ # ¾░Åż
        s/^Stopped/’üŹ/ # ¾░ōø

        # remove extraneous dash if artist is unavailable
        s/^\(\S\+\)  -/\1/
    '
